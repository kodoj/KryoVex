{
  "name": "kryovex",
  "productName": "KryoVex",
  "version": "1.0.0",
  "description": "Counter-Strike 2 Storage unit manager that helps you move items in bulk without the clicking. ",
  "type": "module",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "*.json,.{eslintrc,prettierrc}": [
      "prettier --ignore-path .prettierignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ]
  },
  "author": {
    "name": "Credskiz"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "@testing-library/jest-dom": {
      "cheerio": "1.0.0-rc.12"
    },
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "@node-steam/vdf": "^2.2.0",
    "@xmldom/xmldom": "^0.8.11",
    "axios": "^1.11.0",
    "bytebuffer": "^5.0.1",
    "core-js": "^3.45.1",
    "currency-converter-lt": "^2.0.1",
    "electron-debug": "^3.2.0",
    "electron-dl": "^3.3.0",
    "electron-log": "^4.4.8",
    "electron-redux": "^1.5.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.8",
    "find-process": "^1.4.11",
    "globaloffensive": "^3.2.0",
    "got": "^14.4.7",
    "history": "4.x.x",
    "lodash": "^4.17.21",
    "p-queue": "^8.1.0",
    "ps-list": "^8.1.1",
    "regenerator-runtime": "^0.13.9",
    "steam-session": "^1.1.1",
    "steam-totp": "^2.1.1",
    "steam-user": "^5.2.3",
    "update-electron-app": "^2.0.1"
  },
  "engines": {
    "node": ">=20.x",
    "npm": ">=10.x"
  },
  "main": "dist/main/main.mjs"
}