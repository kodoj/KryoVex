{
  "name": "kryovex",
  "productName": "KryoVex",
  "version": "1.0.0",
  "description": "Counter-Strike 2 Storage unit manager that helps you move items in bulk without the clicking.",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:main": "cross-env NODE_ENV=production BUILD_TARGET=prod tsup",
    "build:renderer": "cross-env NODE_ENV=production BUILD_TARGET=prod vite build",
    "clean": "rimraf dist release node_modules/.cache node_modules/.vite .vite && mkdirp release/app && node scripts/sync-release-app-package.mjs",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "package:compile": "node --import tsx ./.erb/scripts/clean.js dist && node scripts/sync-release-app-package.mjs && npm run build && node scripts/sync-release-dist.mjs && cd release/app && npm install --omit=dev && cd ../..",
    "electron:release": "electron release/app",
    "package:local": "npm run package:compile && electron-builder build --publish never",
    "package": "npm run package:compile && electron-builder build --publish always",
    "package:win": "npm run package:compile && electron-builder build --win --publish never",
    "package:win:publish": "npm run package:compile && electron-builder build --win --publish always",
    "package:mac": "npm run package:compile && electron-builder build --mac --publish never",
    "package:linux": "npm run package:compile && electron-builder build --linux --publish never",
    "postinstall": "node .erb/scripts/check-native-dep.js",
    "start": "node ./.erb/scripts/check-port-in-use.js && npm run dev",
    "dev": "cross-env NODE_ENV=development BUILD_TARGET=dev ELECTRON_IS_DEV=1 node scripts/dev-fast.mjs",
    "dev:watch": "cross-env NODE_ENV=development BUILD_TARGET=dev ELECTRON_IS_DEV=1 concurrently --names \"TSUP,VITE\" --prefix \"[{time} {name}]\" --timestamps --timestamp-format \"HH:mm:ss.SSS\" \"tsup --watch\" \"vite\"",
    "test": "cross-env NODE_ENV=development jest",
    "electron-dev": "electron .",
    "electron-trace": "electron --trace-warnings .",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/sync-app-icon.mjs",
    "icon:sync": "node scripts/sync-app-icon.mjs",
    "logo:alpha": "node scripts/transparent-logo-bg.mjs",
    "asset:wordmark-webp": "node scripts/encode-wordmark-webp.mjs"
  },
  "type": "module",
  "main": "dist/main/main.mjs",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "*.json,.{eslintrc,prettierrc}": [
      "prettier --ignore-path .prettierignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ]
  },
  "build": {
    "productName": "KryoVex",
    "icon": "icon.png",
    "appId": "com.kryovex.app",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "afterSign": ".erb/scripts/notarize.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "synopsis": "CS2 storage unit and inventory management",
      "maintainer": "Credskiz",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Credskiz",
      "repo": "KryoVex",
      "releaseType": "release"
    }
  },
  "author": {
    "name": "Credskiz"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/renderer/$1",
      "^renderer/(.*)$": "<rootDir>/src/renderer/$1",
      "^shared/(.*)$": "<rootDir>/src/shared/$1",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/release/app/"
    ],
    "testPathIgnorePatterns": [
      "release/app/dist"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.cjs"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!redux-persist/)"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@headlessui/react": "^2.2.9",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/globaloffensive": "^2.3.4",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@types/source-map-support": "^0.5.10",
    "@types/steam-user": "^5.1.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@uconn-its/react-chartjs-2-react19-temp": "^5.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "detect-port": "^2.1.0",
    "dotenv": "^17.4.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-notarize": "^1.2.2",
    "electron-winstaller": "^5.4.0",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "events": "^3.3.0",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "redux-persist": "^6.0.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "source-map-support": "^0.5.21",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.4"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "@testing-library/jest-dom": {
      "cheerio": "1.0.0-rc.12"
    },
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@node-steam/vdf": "^2.2.0",
    "@xmldom/xmldom": "^0.9.9",
    "axios": "^1.14.0",
    "bytebuffer": "^5.0.1",
    "core-js": "^3.49.0",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "globaloffensive": "^3.3.0",
    "lodash": "^4.18.1",
    "p-queue": "^9.1.1",
    "ps-list": "^9.0.0",
    "regenerator-runtime": "^0.14.1",
    "steam-session": "^1.9.4",
    "steam-totp": "^2.1.2",
    "steam-user": "^5.3.0"
  },
  "engines": {
    "node": ">=20.x",
    "npm": ">=10.x"
  },
  "browserslist": [],
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
