{
  "name": "kryovex",
  "productName": "KryoVex",
  "version": "1.0.0",
  "description": "Counter-Strike 2 Storage unit manager that helps you move items in bulk without the clicking.",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:main": "cross-env NODE_ENV=production BUILD_TARGET=prod tsup",
    "build:renderer": "cross-env NODE_ENV=production BUILD_TARGET=prod vite build",
    "clean": "rimraf dist release node_modules/.cache .vite && mkdirp release/app && node scripts/sync-release-app-package.mjs",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "package:compile": "node --import tsx ./.erb/scripts/clean.js dist && node scripts/sync-release-app-package.mjs && npm run build && node scripts/sync-release-dist.mjs && cd release/app && npm install --omit=dev && cd ../..",
    "electron:release": "electron release/app",
    "package:local": "npm run package:compile && electron-builder build --publish never",
    "package": "npm run package:compile && electron-builder build --publish always",
    "package:win": "npm run package:compile && electron-builder build --win --publish never",
    "package:mac": "npm run package:compile && electron-builder build --mac --publish never",
    "package:linux": "npm run package:compile && electron-builder build --linux --publish never",
    "postinstall": "node .erb/scripts/check-native-dep.js",
    "start": "node ./.erb/scripts/check-port-in-use.js && npm run dev",
    "dev": "cross-env NODE_ENV=development BUILD_TARGET=dev node scripts/dev-fast.mjs",
    "dev:watch": "cross-env NODE_ENV=development BUILD_TARGET=dev concurrently --names \"TSUP,VITE\" --prefix \"[{time} {name}]\" --timestamps --timestamp-format \"HH:mm:ss.SSS\" \"tsup --watch\" \"vite\"",
    "test": "cross-env NODE_ENV=development jest",
    "electron-dev": "electron .",
    "electron-trace": "electron --trace-warnings .",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/sync-app-icon.mjs",
    "icon:sync": "node scripts/sync-app-icon.mjs",
    "logo:alpha": "node scripts/transparent-logo-bg.mjs"
  },
  "type": "module",
  "main": "dist/main/main.mjs",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "*.json,.{eslintrc,prettierrc}": [
      "prettier --ignore-path .prettierignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .prettierignore --single-quote --write"
    ]
  },
  "build": {
    "productName": "KryoVex",
    "icon": "icon.png",
    "appId": "com.kryovex.app",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "afterSign": ".erb/scripts/notarize.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "synopsis": "CS2 storage unit and inventory management",
      "maintainer": "Credskiz",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Credskiz",
      "repo": "KryoVex",
      "releaseType": "release"
    }
  },
  "author": {
    "name": "Credskiz"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/renderer/$1",
      "^renderer/(.*)$": "<rootDir>/src/renderer/$1",
      "^shared/(.*)$": "<rootDir>/src/shared/$1",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/release/app/"
    ],
    "testPathIgnorePatterns": [
      "release/app/dist",
      "<rootDir>/local_modules/"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.cjs"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@headlessui/react": "^2.2.7",
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@redux-beacon/google-analytics": "^1.2.3",
    "@reduxjs/toolkit": "^2.8.2",
    "@svgr/core": "^6.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/globaloffensive": "^2.3.4",
    "@types/history": "4.7.9",
    "@types/jest": "^27.0.2",
    "@types/lodash": "^4.17.20",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/react-router": "^5.1.17",
    "@types/react-router-dom": "^5.3.2",
    "@types/react-test-renderer": "^18.3.0",
    "@types/reselect": "^2.0.27",
    "@types/source-map-support": "^0.5.10",
    "@types/steam-user": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@uconn-its/react-chartjs-2-react19-temp": "^5.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "chalk": "^4.1.2",
    "chart.js": "^4.5.0",
    "chartjs-plugin-datalabels": "^2.0.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "detect-port": "^1.3.0",
    "dotenv": "^16.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.20",
    "electron-devtools-installer": "^4.0.0",
    "electron-notarize": "^1.1.1",
    "electron-winstaller": "^5.1.0",
    "electronmon": "^2.0.3",
    "eslint": "^9.34.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "events": "^3.3.0",
    "foreach": "file:local_modules/foreach",
    "glob": "^11.0.0",
    "husky": "7.0.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "lint-staged": "^11.2.6",
    "minimatch": "^10.0.3",
    "postcss": "^8.5.6",
    "prettier": "^2.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-qr-code": "^2.0.11",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.8.2",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
    "reselect": "^5.1.1",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "semver": "^7.7.2",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.12",
    "ts-jest": "^29.4.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2",
    "uuid": "^11.0.0",
    "vite": "^7.1.4",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-html": "^3.2.2",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "@testing-library/jest-dom": {
      "cheerio": "1.0.0-rc.12"
    },
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "@node-steam/vdf": "^2.2.0",
    "@xmldom/xmldom": "^0.8.12",
    "axios": "^1.11.0",
    "bytebuffer": "^5.0.1",
    "core-js": "^3.45.1",
    "electron-debug": "^3.2.0",
    "electron-dl": "^3.3.0",
    "electron-log": "^4.4.8",
    "electron-redux": "^1.5.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.8",
    "find-process": "^1.4.11",
    "globaloffensive": "^3.2.0",
    "got": "^14.4.7",
    "history": "4.x.x",
    "lodash": "^4.18.1",
    "p-queue": "^8.1.0",
    "ps-list": "^8.1.1",
    "regenerator-runtime": "^0.13.9",
    "steam-session": "^1.1.1",
    "steam-totp": "^2.1.1",
    "steam-user": "^5.2.3",
    "update-electron-app": "^2.0.1"
  },
  "engines": {
    "node": ">=20.x",
    "npm": ">=10.x"
  },
  "browserslist": [],
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
